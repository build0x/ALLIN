# ========== 服务与数据库（必填） ==========
PORT=5700
DB_HOST=localhost
DB_USER=postgres
DB_PASS=你的数据库密码
DB_NAME=poker-pocket-ts

# ========== JWT 与登录（必填，可随机生成长字符串） ==========
# 用于登录 token 签名，建议 64 位十六进制或更长随机串
PW_SECRET=请替换为随机长字符串
# 用于刷新 token 签名
PW_REFRESH_SECRET=请替换为另一组随机长字符串

# ========== 日志 ==========
LOG_LEVEL=info

# ========== 管理后台（可选） ==========
# 允许登录管理后台的钱包地址，多个用英文逗号分隔
ADMIN_WALLETS=

# ========== BSC 链（只读可留空，要提现/销毁/奖池发奖才需填 OPERATOR 私钥） ==========
BSC_RPC_URL=https://bsc-dataseed.binance.org/
# 后端操作钱包私钥：仅在做提现、销毁、奖池发奖等链上写操作时需要，只读/展示可留空
BSC_OPERATOR_PRIVATE_KEY=

# ========== 合约地址（与前端/链上部署一致） ==========
# 代币：若在发币平台部署，先填平台部署得到的地址，再执行 deploy-others-with-token.js
ALLIN_TOKEN_ADDRESS=0xbe3fd46ca68dc40be81ee30a866ae5592ed07777
GAME_TREASURY_VAULT_ADDRESS=0x60F586D49dC884b270FD578ae1a1D70149918e69
# 用户直接调用的游戏合约（报名/建房），必填
ALLIN_GAME_ADDRESS=
PRIZE_POOL_VAULT_ADDRESS=
# 收税转发器（先执行 deploy-tax-forwarder.js 后自动写入；用于一键部署时设置奖池）
# TAX_FORWARDER_ADDRESS=

# ========== 可选：链上确认块数、起始区块 ==========
# ONCHAIN_CONFIRMATIONS=1
# ONCHAIN_START_BLOCK=0
